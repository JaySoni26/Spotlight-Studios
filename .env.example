# Next.js does NOT read this file. Copy to ".env.local" (or ".env") in the same folder, then restart `npm run dev`.
#    cp .env.example .env.local
#
# Required for this app (no local SQLite): remote LibSQL / Turso.
#
# URL must match the database "Connect" tab exactly (libsql://… or https://…).
# HTTP 404 from the API almost always means this URL is wrong or the DB was deleted.

TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Or use these names instead:
# LIBSQL_URL=
# LIBSQL_AUTH_TOKEN=
